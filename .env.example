# DeepSeek API Configuration
# Get your API key from: https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=your_api_key_here

# Optional: Custom API base URL (defaults to https://api.deepseek.com/v1)
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional: Model name (defaults to deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# Session secret for JWT signing (change in production!)
SESSION_SECRET=dev-secret-change-in-production