# OpenAI-Compatible API Configuration
# Get your API key from your OpenAI-compatible provider (e.g. DeepSeek, OpenRouter, etc.)
OPENAI_COMPATIBLE_API_KEY=your_api_key_here

# Optional: Custom API base URL (defaults to https://api.deepseek.com/v1)
# OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com/v1

# Optional: Model name (defaults to deepseek-chat)
# OPENAI_COMPATIBLE_MODEL=deepseek-chat

# Session secret for JWT signing (change in production!)
SESSION_SECRET=dev-secret-change-in-production